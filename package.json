{
  "name": "brain180-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch --env-file=.env server/index.ts",
    "build": "tsc -b && vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "node server.js",
    "start:server": "node --env-file-if-exists=.env dist-server/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@google/genai": "^1.0.0",
    "@node-rs/argon2": "^2.0.2",
    "cookie": "^1.0.2",
    "cytoscape": "^3.33.3",
    "drizzle-orm": "^0.45.2",
    "express": "^5.1.0",
    "lucia": "^3.2.2",
    "openai": "^5.0.0",
    "pg": "^8.21.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "serve": "^14.2.4",
    "zod": "^3.23.8",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/cookie": "^1.0.0",
    "@types/cytoscape": "^3.21.9",
    "@types/express": "^5.0.0",
    "@types/node": "^24.12.2",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.19.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  }
}
