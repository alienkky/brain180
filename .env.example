# Brain180 v2 — 환경변수 인벤토리
# 본 파일은 키 *목록* 만. 실제 값은 절대 커밋하지 말 것. 운영 키는 Railway env vars.
# Owner: 연다리 [통합설계]. Implementation: ALI-67 (방연동[MCP]).

# ── 런타임 ──────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:3000

# ── DB ──────────────────────────────────────────────
# Neon Postgres. app 전용 role 권한만 부여. SUPERUSER/DROP 금지.
DATABASE_URL=postgres://app:CHANGE_ME@localhost:5432/brain180

# ── 익명화 솔트 ─────────────────────────────────────
# 외부 AI/결제 호출 시 userId → sha256(userId+salt) 변환에 사용.
# 운영 시 32바이트 무작위. 키 회전 시 기존 분석/주문 연결 끊김.
ANON_SALT=CHANGE_ME_32_BYTES_RANDOM

# ── 관리자 시드 (ALI-62 차곡담) ─────────────────────
# 부트 시 본 값이 있으면 admin 시드 실행. 없으면 32자 무작위 생성 후 stdout 1회 출력.
# argon2id 해시만 DB 저장. 첫 로그인 시 must_change_password=true 강제.
ADMIN_SEED_EMAIL=kky710@gmail.com
ADMIN_SEED_PASSWORD=

# ── AI 모델 (ALI-66 남말씨 / ALI-67 방연동) ─────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7
# 선택 폴백/보조
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── 이메일 (ALI-67 — Day-1 인프라만) ────────────────
RESEND_API_KEY=
EMAIL_FROM=Brain180 <no-reply@brain180.app>

# ── 결제 (ALI-67 — Day-1 인프라만) ──────────────────
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=
TOSS_WEBHOOK_SECRET=

# ── 스토리지 (ALI-67 — Day-1 인프라만) ──────────────
# Day-1: 비워두면 ./uploads 로컬 디스크 폴백 사용.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=brain180-artifacts
R2_PUBLIC_BASE_URL=

# ── Web Push (ALI-67 — Day-1 인프라만) ──────────────
# 생성: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:no-reply@brain180.app

# ── 세션 (Lucia v3) ─────────────────────────────────
SESSION_SECRET=CHANGE_ME_32_BYTES_RANDOM
SESSION_COOKIE_NAME=b180_session
SESSION_TTL_HOURS=720
